# ---------------------------------------------------------------------------
# DevQuest — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real secrets.
# ---------------------------------------------------------------------------

# Public base URL of the deployed app (used for absolute card/OG URLs).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- GitHub API ------------------------------------------------------------
# Personal access token (classic, read-only public scope is enough) used to
# raise the GitHub API rate limit. Optional for local dev, recommended in prod.
GITHUB_TOKEN=""

# --- GitHub OAuth (Auth.js) — wired up in Prompt 9 -------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Secret used by Auth.js to encrypt sessions. Generate: `openssl rand -base64 32`
AUTH_SECRET=""

# --- Redis stats cache (Upstash) — wired up in Prompt 4 --------------------
# Backed by @upstash/redis. Works with Vercel KV, the Vercel Marketplace
# "Upstash" integration, or a plain Upstash database. The app accepts either
# naming convention below; set ONE pair. When unset, it falls back to an
# in-memory cache for local development.
#
# Vercel KV / Vercel Marketplace Upstash integration:
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
# ...or a plain Upstash Redis database:
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
