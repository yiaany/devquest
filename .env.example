# GitHub OAuth (required for login)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your_random_secret_string

# GitHub API token (optional, but recommended - increases rate limit)
GITHUB_TOKEN=your_personal_access_token

# NextAuth URL
NEXTAUTH_URL=http://localhost:3000

# Upstash Redis / Vercel KV (required for durable guestbook + stats cache).
# Without these, the guestbook falls back to in-memory storage that does NOT
# persist across serverless instances, and signatures won't stick in prod.
# Either naming convention works:
#   Vercel KV / Marketplace Upstash → KV_REST_API_URL / KV_REST_API_TOKEN
#   Plain Upstash database          → UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your_upstash_rest_token
